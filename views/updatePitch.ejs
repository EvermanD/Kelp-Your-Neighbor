<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Update Pitch</title>
    <style>
        body {
            background: #f8f9fa;
        }

        .form-card {
            border: none;
            border-radius: 22px;
            box-shadow: 0 10px 24px rgba(0,0,0,0.08);
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>

        <div class="d-flex align-items-center gap-2">
            <a href="/pitchInfo/<%= pitch.id %>" class="btn btn-outline-light btn-sm">Back to Pitch</a>
            <button class="btn btn-light btn-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#userMenuCanvas" aria-controls="userMenuCanvas">
                <%= user && (user.display_name || user.username) ? (user.display_name || user.username) : 'Menu' %>
            </button>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-5">
    <div class="card form-card">
        <div class="card-body p-4 p-md-5">
            <h1 class="fw-bold mb-3">Update Pitch</h1>
            <p class="text-muted mb-4">Edit your pitch details and change its status.</p>

            <form action="/updatePitch/<%= pitch.id %>" method="POST" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Pitch Title</label>
                    <input type="text" name="title" class="form-control" value="<%= pitch.title %>" required>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Service Name</label>
                    <input type="text" name="name" class="form-control" value="<%= pitch.name %>" required>
                </div>

                <div class="col-12">
                    <label class="form-label">Bio / Description</label>
                    <textarea name="bio" class="form-control" rows="5" required><%= pitch.bio %></textarea>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select" required>
                        <option value="Art" <%= pitch.category === 'Art' ? 'selected' : '' %>>Art</option>
                        <option value="Music" <%= pitch.category === 'Music' ? 'selected' : '' %>>Music</option>
                        <option value="Design" <%= pitch.category === 'Design' ? 'selected' : '' %>>Design</option>
                        <option value="Photography" <%= pitch.category === 'Photography' ? 'selected' : '' %>>Photography</option>
                        <option value="Video" <%= pitch.category === 'Video' ? 'selected' : '' %>>Video</option>
                        <option value="Writing" <%= pitch.category === 'Writing' ? 'selected' : '' %>>Writing</option>
                        <option value="Marketing" <%= pitch.category === 'Marketing' ? 'selected' : '' %>>Marketing</option>
                        <option value="Misc" <%= pitch.category === 'Misc' ? 'selected' : '' %>>Misc</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" value="<%= pitch.location || '' %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Location Type</label>
                    <select name="location_type" class="form-select">
                        <option value="On-site" <%= pitch.location_type === 'On-site' ? 'selected' : '' %>>On-site</option>
                        <option value="Remote" <%= pitch.location_type === 'Remote' ? 'selected' : '' %>>Remote</option>
                        <option value="Hybrid" <%= pitch.location_type === 'Hybrid' ? 'selected' : '' %>>Hybrid</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Rate Type</label>
                    <select name="rate_type" class="form-select">
                        <option value="Fixed" <%= pitch.rate_type === 'Fixed' ? 'selected' : '' %>>Fixed</option>
                        <option value="Hourly" <%= pitch.rate_type === 'Hourly' ? 'selected' : '' %>>Hourly</option>
                        <option value="Negotiable" <%= pitch.rate_type === 'Negotiable' ? 'selected' : '' %>>Negotiable</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Rate Min</label>
                    <input type="number" step="0.01" name="rate_min" class="form-control" value="<%= pitch.rate_min ?? '' %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Rate Max</label>
                    <input type="number" step="0.01" name="rate_max" class="form-control" value="<%= pitch.rate_max ?? '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Availability</label>
                    <input type="text" name="availability" class="form-control" value="<%= pitch.availability || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Contact Email</label>
                    <input type="email" name="contact_email" class="form-control" value="<%= pitch.contact_email || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Portfolio Link</label>
                    <input type="text" name="portfolio" class="form-control" value="<%= pitch.portfolio || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Image URL</label>
                    <input type="text" name="image_url" class="form-control" value="<%= pitch.image_url || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="Open" <%= pitch.status === 'Open' ? 'selected' : '' %>>Open</option>
                        <option value="Filled" <%= pitch.status === 'Filled' ? 'selected' : '' %>>Filled</option>
                        <option value="Completed" <%= pitch.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                        <option value="Closed" <%= pitch.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                    </select>
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="beginner_friendly" value="1" id="beginnerFriendly" <%= pitch.beginner_friendly ? 'checked' : '' %>>
                        <label class="form-check-label" for="beginnerFriendly">
                            Beginner Friendly
                        </label>
                    </div>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/pitchInfo/<%= pitch.id %>" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
