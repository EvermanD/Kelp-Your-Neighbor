<div class="profile-menu-anchor">
    <button
        class="nav-profile-btn profile-menu-trigger"
        type="button"
        id="profileMenuTrigger"
        aria-expanded="false"
        aria-haspopup="true"
        aria-controls="profileMenuDropdown"
    >
        <img
            src="<%= profileImageUrl && profileImageUrl.trim() !== '' ? profileImageUrl : 'https://via.placeholder.com/80x80?text=U' %>"
            alt="Profile"
        >
    </button>
</div>