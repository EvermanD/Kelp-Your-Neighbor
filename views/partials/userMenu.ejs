<div
    class="profile-menu-dropdown"
    id="profileMenuDropdown"
    role="menu"
    aria-labelledby="profileMenuTrigger"
    hidden
>
    <% if (typeof user !== 'undefined' && user) { %>
        <div class="profile-menu-card">
            <div class="profile-menu-header">
                <img
                    src="<%= user.profile_image_url && user.profile_image_url.trim() !== '' ? user.profile_image_url : 'https://via.placeholder.com/120x120?text=Profile' %>"
                    alt="Profile"
                    class="profile-menu-avatar"
                >

                <div class="profile-menu-user">
                    <div class="profile-menu-name"><%= user.display_name || user.username %></div>
                    <div class="profile-menu-type"><%= user.profile_type || 'individual' %></div>
                </div>
            </div>

            <div class="profile-menu-links">
                <a href="/profile" class="profile-menu-link" role="menuitem">
                    <span class="profile-menu-link-title">My Profile</span>
                    <span class="profile-menu-link-subtitle">View your profile, saved items, and activity</span>
                </a>

                <a href="/updateProfile" class="profile-menu-link" role="menuitem">
                    <span class="profile-menu-link-title">Edit Profile</span>
                    <span class="profile-menu-link-subtitle">Update your image, bio, and portfolio</span>
                </a>

                <a href="/logout" class="profile-menu-link profile-menu-link-danger" role="menuitem">
                    <span class="profile-menu-link-title">Logout</span>
                    <span class="profile-menu-link-subtitle">Sign out of OtterGigs</span>
                </a>
            </div>
        </div>
    <% } %>
</div>

<script src="/js/userMenu.js"></script>