<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Home</title>
</head>
<body class="page-home">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <div class="navbar-controls">
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: user && user.profile_image_url }) %>
            <%- include("partials/navActions.ejs") %>
        </div>

        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<%
    const featuredBusinesses = [
        {
            name: "Cypress Coast Coffee",
            city: "Monterey",
            type: "Sample coffee shop",
            imageUrl: "https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=1200&q=80"
        },
        {
            name: "Lighthouse Letterpress",
            city: "Pacific Grove",
            type: "Sample bookstore",
            imageUrl: "https://images.unsplash.com/photo-1526243741027-444d633d7365?auto=format&fit=crop&w=1200&q=80"
        },
        {
            name: "Marina Salt & Butter",
            city: "Marina",
            type: "Sample bakery",
            imageUrl: "https://images.unsplash.com/photo-1517433670267-08bbd4be890f?auto=format&fit=crop&w=1200&q=80"
        },
        {
            name: "Sandbar Social Kitchen",
            city: "Seaside",
            type: "Sample restaurant",
            imageUrl: "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1200&q=80"
        },
        {
            name: "Carmel Tide Gallery",
            city: "Carmel",
            type: "Sample art gallery",
            imageUrl: "https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?auto=format&fit=crop&w=1200&q=80"
        },
        {
            name: "Wharf & Bloom Boutique",
            city: "Monterey",
            type: "Sample boutique",
            imageUrl: "https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=1200&q=80"
        },
        {
            name: "Ocean Porch Market",
            city: "Pacific Grove",
            type: "Sample neighborhood cafe",
            imageUrl: "https://images.unsplash.com/photo-1445116572660-236099ec97a0?auto=format&fit=crop&w=1200&q=80"
        }
    ];
%>

<div class="container py-5">
    <div class="card hero-card mb-4">
        <div class="card-body p-4 p-md-5">
            <h1 class="display-6 fw-bold mb-3">Where Monterey Bay creativity meets local opportunity</h1>
            <p class="lead mb-2">
                Discover gigs, creators, and collaborations happening across students, artists, and local businesses.
            </p>
            <p class="mb-4">
                Welcome back,
                <strong><%= user.display_name || user.username %></strong>
                — your community is active right now.
            </p>

            <div class="d-flex flex-wrap gap-3">
                <a href="/findGig" class="btn hero-btn-primary btn-lg">Find a Gig</a>
                <a href="/findPitch" class="btn hero-btn-primary btn-lg">Find a Pitch</a>
                <a href="/postGig" class="btn hero-btn-secondary btn-lg">Post a Gig</a>
                <a href="/postPitch" class="btn hero-btn-secondary btn-lg">Post a Pitch</a>
                <a href="/profile" class="btn hero-btn-secondary btn-lg">View Profile</a>
            </div>
        </div>
    </div>

    <section class="local-businesses-section mb-5" aria-labelledby="local-businesses-title">
        <div class="local-businesses-shell">
            <div class="local-businesses-header">
                <div>
                    <p class="local-businesses-eyebrow mb-2">Community Spotlight</p>
                    <h2 id="local-businesses-title" class="local-businesses-title mb-2">Explore Local Businesses</h2>
                    <p class="local-businesses-subtitle mb-0">
                        Discover local spots from Monterey, Pacific Grove, Marina, Seaside, and Carmel.
                    </p>
                </div>

                <div class="local-businesses-controls" aria-label="Business carousel controls">
                    <button type="button" class="local-businesses-control" data-carousel-prev aria-label="Show previous businesses">
                        <span aria-hidden="true">&larr;</span>
                    </button>
                    <button type="button" class="local-businesses-control" data-carousel-next aria-label="Show next businesses">
                        <span aria-hidden="true">&rarr;</span>
                    </button>
                </div>
            </div>

            <div class="local-businesses-note">Sample showcase cards inspired by Monterey County business types.</div>

            <div class="local-businesses-carousel" data-business-carousel>
                <div class="local-businesses-viewport">
                    <div class="local-businesses-track" data-carousel-track>
                        <% featuredBusinesses.forEach((business) => { %>
                            <article class="local-business-card" data-carousel-card>
                                <div class="local-business-card__media">
                                    <img src="<%= business.imageUrl %>" alt="<%= business.name %>" class="local-business-card__image">
                                    <div class="local-business-card__overlay"></div>

                                    <div class="local-business-card__content">
                                        <span class="local-business-card__badge">Sample local spot</span>
                                        <h3 class="local-business-card__title"><%= business.name %></h3>
                                        <p class="local-business-card__meta mb-0"><%= business.city %> • <%= business.type %></p>
                                    </div>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-live-shell mb-5" aria-labelledby="home-live-title">
    <div class="home-live-header mb-3">
        <div>
            <p class="local-businesses-eyebrow mb-2">Live OtterGigs</p>
            <h2 id="home-live-title" class="local-businesses-title mb-2">What’s happening in the community right now</h2>
            <p class="local-businesses-subtitle mb-0">
                Fresh activity from local gigs, creators, collaborations, and reviews.
            </p>
        </div>
    </div>

    <div class="row g-3 mb-3" id="homeStatsGrid">
        <div class="col-6 col-lg-3">
            <article class="home-stat-card">
                <div class="home-stat-label">Open Gigs</div>
                <div class="home-stat-value" data-home-stat="openGigs">--</div>
            </article>
        </div>
        <div class="col-6 col-lg-3">
            <article class="home-stat-card">
                <div class="home-stat-label">Open Pitches</div>
                <div class="home-stat-value" data-home-stat="openPitches">--</div>
            </article>
        </div>
        <div class="col-6 col-lg-3">
            <article class="home-stat-card">
                <div class="home-stat-label">Areas Active</div>
                <div class="home-stat-value" data-home-stat="activeAreas">--</div>
            </article>
        </div>
        <div class="col-6 col-lg-3">
            <article class="home-stat-card">
                <div class="home-stat-label">Completed Collaborations</div>
                <div class="home-stat-value" data-home-stat="completedWork">--</div>
            </article>
        </div>
    </div>

    <div class="home-activity-shell">
        <div class="home-activity-title">Recent community activity</div>
        <div class="home-activity-list" id="homeActivityList">
            <div class="home-activity-empty">Loading recent activity...</div>
        </div>
    </div>
</section>

<div class="row g-4 mb-5">
    <div class="col-lg-5">
        <section class="home-spotlight-card h-100" aria-labelledby="home-spotlight-title">
            <p class="local-businesses-eyebrow mb-2">This week’s spotlight</p>
            <h2 id="home-spotlight-title" class="home-section-title mb-2">Featured local profile</h2>
            <p class="home-section-copy mb-4">
                Highlighting a local business or creator who is actively posting and building community momentum.
            </p>

            <div id="homeSpotlightCard" class="home-spotlight-body">
                <div class="home-loading-state">Loading spotlight...</div>
            </div>
        </section>
    </div>

    <div class="col-lg-7">
        <section class="home-pulse-card h-100" aria-labelledby="home-pulse-title">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <p class="local-businesses-eyebrow mb-2">Community pulse</p>
                    <h2 id="home-pulse-title" class="home-section-title mb-2">Fresh opportunities and creator activity</h2>
                    <p class="home-section-copy mb-0">
                        Toggle between gigs and pitches to see what was posted most recently.
                    </p>
                </div>

                <div class="home-pulse-toggle-group" role="tablist" aria-label="Toggle community pulse feed">
                    <button class="home-pulse-toggle active" type="button" data-pulse-type="gig">Gigs</button>
                    <button class="home-pulse-toggle" type="button" data-pulse-type="pitch">Pitches</button>
                </div>
            </div>

            <div class="home-pulse-rotator mb-3" id="homePulseRotator">Loading updates...</div>

            <div class="home-pulse-list" id="homePulseList">
                <div class="home-loading-state">Loading pulse feed...</div>
            </div>
        </section>
    </div>
</div>

<section class="home-map-shell mb-5" aria-labelledby="home-map-title">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <p class="local-businesses-eyebrow mb-2">Community map</p>
            <h2 id="home-map-title" class="home-section-title mb-2">See where creativity is happening</h2>
            <p class="home-section-copy mb-0">
                Explore open gigs and pitches around Monterey, Marina, Seaside, Pacific Grove, Carmel, and CSUMB.
            </p>
        </div>

        <div class="map-toggle-group">
            <button type="button" class="btn-map-toggle active" data-map-type="gig">Show Gigs</button>
            <button type="button" class="btn-map-toggle" data-map-type="pitch">Show Pitches</button>
        </div>
    </div>

    <div id="localMap" class="local-map-frame home-map-frame rounded-4"></div>
</section>

<script src="https://cdn.jsdelivr.net/npm/animejs@4.0.2/lib/anime.iife.min.js"></script>
<link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
/>
<script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
></script>

<script src="/js/homeCarousel.js"></script>
<script src="/js/localMap.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const statsMap = {
        openGigs: document.querySelector('[data-home-stat="openGigs"]'),
        openPitches: document.querySelector('[data-home-stat="openPitches"]'),
        activeAreas: document.querySelector('[data-home-stat="activeAreas"]'),
        completedWork: document.querySelector('[data-home-stat="completedWork"]')
    };

    const activityList = document.getElementById("homeActivityList");
    const spotlightCard = document.getElementById("homeSpotlightCard");
    const pulseList = document.getElementById("homePulseList");
    const pulseRotator = document.getElementById("homePulseRotator");
    const pulseButtons = Array.from(document.querySelectorAll("[data-pulse-type]"));

    let currentPulseType = "gig";
    let pulseMessages = [];
    let pulseMessageIndex = 0;
    let pulseInterval = null;

    function formatTimeAgo(value) {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return "";

        const seconds = Math.floor((Date.now() - date.getTime()) / 1000);

        if (seconds < 60) return "just now";
        if (seconds < 3600) return Math.floor(seconds / 60) + " min ago";
        if (seconds < 86400) return Math.floor(seconds / 3600) + " hr ago";
        return Math.floor(seconds / 86400) + " day" + (Math.floor(seconds / 86400) === 1 ? "" : "s") + " ago";
    }

    function escapeHtml(value) {
        return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    function startPulseRotation() {
        if (pulseInterval) {
            clearInterval(pulseInterval);
            pulseInterval = null;
        }

        if (!pulseMessages.length) return;

        pulseRotator.textContent = pulseMessages[0];
        pulseMessageIndex = 0;

        if (pulseMessages.length === 1) return;

        pulseInterval = window.setInterval(() => {
            pulseMessageIndex = (pulseMessageIndex + 1) % pulseMessages.length;
            pulseRotator.textContent = pulseMessages[pulseMessageIndex];
        }, 3200);
    }

    async function loadStats() {
        try {
            const response = await fetch("/api/home-stats");
            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.error || "Unable to load home stats.");
            }

            statsMap.openGigs.textContent = data.openGigs;
            statsMap.openPitches.textContent = data.openPitches;
            statsMap.activeAreas.textContent = data.activeAreas;
            statsMap.completedWork.textContent = data.completedWork;

            if (!Array.isArray(data.recentActivity) || data.recentActivity.length === 0) {
                activityList.innerHTML = '<div class="home-activity-empty">No recent activity yet.</div>';
                return;
            }

            activityList.innerHTML = data.recentActivity.map(item => {
                return `
                    <a href="${item.url}" class="home-activity-item">
                        <span class="home-activity-dot"></span>
                        <div>
                            <div class="home-activity-text">${escapeHtml(item.text)}</div>
                            <div class="home-activity-time">${formatTimeAgo(item.created_at)}</div>
                        </div>
                    </a>
                `;
            }).join("");
        } catch (error) {
            activityList.innerHTML = '<div class="home-activity-empty">Unable to load activity right now.</div>';
        }
    }

    async function loadSpotlight() {
        try {
            const response = await fetch("/api/home-spotlight");
            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.error || "Unable to load spotlight.");
            }

            spotlightCard.innerHTML = `
                <div class="home-spotlight-profile">
                    <img
                        src="${escapeHtml(data.profile_image_url || "/img/defaultImage.jpg")}"
                        alt="${escapeHtml(data.name)}"
                        class="home-spotlight-avatar"
                    />

                    <div class="home-spotlight-meta">
                        <div class="home-spotlight-name">${escapeHtml(data.name)}</div>
                        <div class="home-spotlight-subtitle">${escapeHtml(data.profile_type_label)}</div>
                        <div class="home-spotlight-location">${escapeHtml(data.location || "Monterey Bay area")}</div>
                    </div>
                </div>

                <div class="home-spotlight-summary">
                    ${escapeHtml(data.summary)}
                </div>

                <div class="home-spotlight-tags">
                    <span class="home-spotlight-tag">${data.open_gigs} open gig${data.open_gigs === 1 ? "" : "s"}</span>
                    <span class="home-spotlight-tag">${data.open_pitches} open pitch${data.open_pitches === 1 ? "" : "es"}</span>
                </div>

                <a href="/profile/${data.id}" class="btn btn-home-ocean mt-3">View Spotlight Profile</a>
            `;
        } catch (error) {
            spotlightCard.innerHTML = '<div class="home-loading-state">Unable to load spotlight right now.</div>';
        }
    }

    async function loadPulse(type) {
        currentPulseType = type;

        pulseButtons.forEach(button => {
            button.classList.toggle("active", button.dataset.pulseType === type);
        });

        pulseList.innerHTML = '<div class="home-loading-state">Loading pulse feed...</div>';

        try {
            const response = await fetch("/api/home-pulse?type=" + encodeURIComponent(type));
            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.error || "Unable to load pulse.");
            }

            pulseMessages = Array.isArray(data.updates) ? data.updates : [];
            startPulseRotation();

            if (!Array.isArray(data.items) || data.items.length === 0) {
                pulseList.innerHTML = '<div class="home-loading-state">No recent items yet.</div>';
                return;
            }

            pulseList.innerHTML = data.items.map(item => {
                return `
                    <a href="${item.url}" class="home-pulse-item">
                        <div class="home-pulse-item-main">
                            <div class="home-pulse-item-title">${escapeHtml(item.title)}</div>
                            <div class="home-pulse-item-meta">
                                ${escapeHtml(item.location || "Local")} • ${escapeHtml(item.category || "Community")}
                            </div>
                        </div>
                        <div class="home-pulse-item-time">${formatTimeAgo(item.created_at)}</div>
                    </a>
                `;
            }).join("");
        } catch (error) {
            pulseRotator.textContent = "Unable to load rotating updates right now.";
            pulseList.innerHTML = '<div class="home-loading-state">Unable to load pulse feed.</div>';
        }
    }

    pulseButtons.forEach(button => {
        button.addEventListener("click", function () {
            loadPulse(button.dataset.pulseType);
        });
    });

    loadStats();
    loadSpotlight();
    loadPulse("gig");
});
</script>
</body>
</html>
