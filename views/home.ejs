<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Home</title>
    <style>
        body {
            background: #f8f9fa;
        }

        .hero-card {
            border: none;
            border-radius: 24px;
            overflow: hidden;
            background: linear-gradient(135deg, #0d6efd, #20c997);
            color: white;
            box-shadow: 0 12px 28px rgba(0,0,0,0.12);
        }

        .action-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 24px rgba(0,0,0,0.08);
            transition: transform 0.2s ease;
            height: 100%;
        }

        .action-card:hover {
            transform: translateY(-4px);
        }

        .nav-profile-btn {
            width: 42px;
            height: 42px;
            padding: 0;
            border-radius: 50%;
            overflow: hidden;
            border: none;
            background: transparent;
        }

        .nav-profile-btn img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid white;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">OtterGigs</a>

        <div class="d-flex align-items-center gap-2 flex-wrap">
            <a href="/findGig" class="btn btn-outline-light btn-sm">Find Gig</a>
            <a href="/findPitch" class="btn btn-outline-light btn-sm">Find Pitch</a>

            <button class="nav-profile-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#userMenuCanvas" aria-controls="userMenuCanvas">
                <img
                    src="<%= user && user.profile_image_url && user.profile_image_url.trim() !== '' ? user.profile_image_url : 'https://via.placeholder.com/80x80?text=U' %>"
                    alt="Profile"
                >
            </button>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-5">
    <div class="card hero-card mb-4">
        <div class="card-body p-4 p-md-5">
            <h1 class="display-6 fw-bold mb-3">Welcome to OtterGigs</h1>
            <p class="lead mb-2">A local creative gig board for students, artists, and community opportunities.</p>
            <p class="mb-4">
                Signed in as
                <strong><%= user.display_name || user.username %></strong>
            </p>

            <div class="d-flex flex-wrap gap-3">
                <a href="/findGig" class="btn btn-light btn-lg">Find a Gig</a>
                <a href="/findPitch" class="btn btn-light btn-lg">Find a Pitch</a>
                <a href="/postGig" class="btn btn-outline-light btn-lg">Post a Gig</a>
                <a href="/postPitch" class="btn btn-outline-light btn-lg">Post a Pitch</a>
                <a href="/profile" class="btn btn-outline-light btn-lg">View Profile</a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-xl-3">
            <div class="card action-card">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Browse Gigs</h4>
                    <p class="text-muted">Search local opportunities by category, urgency, and location.</p>
                    <a href="/findGig" class="btn btn-primary">Go to Find Gig</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card action-card">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Browse Pitches</h4>
                    <p class="text-muted">Explore creator profiles, services, and skill offerings.</p>
                    <a href="/findPitch" class="btn btn-primary">Go to Find Pitch</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card action-card">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Post a Gig</h4>
                    <p class="text-muted">Need help from a creative? Post a gig for students and locals.</p>
                    <a href="/postGig" class="btn btn-success">Go to Post Gig</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card action-card">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Post a Pitch</h4>
                    <p class="text-muted">Offer your services so people can discover your work.</p>
                    <a href="/postPitch" class="btn btn-success">Go to Post Pitch</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-md-6">
            <div class="card action-card">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Your Profile</h4>
                    <p class="text-muted">Manage your profile, posted gigs, posted pitches, and saved items.</p>
                    <a href="/profile" class="btn btn-dark">Go to Profile</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>