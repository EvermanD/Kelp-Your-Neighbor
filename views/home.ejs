<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Home</title>
</head>
<body>
<%- include("partials/navbar.ejs") %>

<div class="container py-5">
    <div class="p-4 p-md-5 bg-light rounded-3 border">
        <h1 class="display-6 fw-bold mb-3">Welcome to OtterGigs</h1>
        <p class="lead mb-2">
            Find local creative gigs and connect with opportunities in your community.
        </p>
        <% if (username) { %>
            <p class="text-muted mb-4">Logged in as <strong><%= username %></strong></p>
        <% } %>

        <div class="d-flex gap-3 flex-wrap">
            <a href="/findGig" class="btn btn-primary btn-lg">Find a Gig</a>
            <a href="/postGig" class="btn btn-secondary btn-lg">Post a Gig</a>
        </div>
    </div>
</div>
</body>
</html>