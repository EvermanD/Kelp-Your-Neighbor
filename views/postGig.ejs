<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Post Gig</title>
    <style>
        .location-card {
            background: linear-gradient(180deg, #f8fcff 0%, #eef7fb 100%);
            border: 1px solid rgba(22, 50, 79, 0.08);
            border-radius: 18px;
            padding: 1rem;
        }

        .location-card-title {
            font-weight: 700;
            color: #16324f;
            margin-bottom: 0.25rem;
        }

        .location-card-text {
            color: #5b7083;
            font-size: 0.95rem;
            margin-bottom: 0;
        }

        .location-select,
        .location-type-select {
            min-height: 48px;
            border-radius: 14px;
        }

        .location-hint-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.75rem;
        }

        .location-hint-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.35rem 0.75rem;
            border-radius: 999px;
            background: #ffffff;
            border: 1px solid rgba(22, 50, 79, 0.10);
            color: #244b68;
            font-size: 0.85rem;
            font-weight: 600;
        }
    </style>
</head>
<body class="page-post-gig">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <div class="navbar-controls">
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: user && user.profile_image_url }) %>
            <%- include("partials/navActions.ejs") %>
        </div>

        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-5">
    <div class="page-form-hero">
        <h1 class="fw-bold mb-2">Post a Gig</h1>
        <p class="mb-0">Create a new gig for local creatives and students.</p>
    </div>

    <div class="card form-card">
        <div class="card-body p-4 p-md-5">
            <form action="/postGig" method="POST" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Gig Title</label>
                    <input type="text" name="title" class="form-control" required>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Looking For</label>
                    <input type="text" name="looking_for" class="form-control" placeholder="Photographer, Designer..." required>
                </div>

                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="5" required></textarea>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select" required>
                        <option value="">Choose one</option>
                        <option value="Art">Art</option>
                        <option value="Music">Music</option>
                        <option value="Design">Design</option>
                        <option value="Photography">Photography</option>
                        <option value="Video">Video</option>
                        <option value="Writing">Writing</option>
                        <option value="Marketing">Marketing</option>
                        <option value="Misc">Misc</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Organization Name</label>
                    <input type="text" name="organization_name" class="form-control" value="<%= user.display_name || '' %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Urgency</label>
                    <select name="urgency" class="form-select" required>
                        <option value="Low">Low</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">High</option>
                        <option value="Urgent">Urgent</option>
                    </select>
                </div>

                <div class="col-12">
                    <div class="location-card">
                        <div class="mb-3">
                            <h5 class="location-card-title">Where is this gig based?</h5>
                            <p class="location-card-text">
                                Choose a standard area so your gig shows up correctly in search filters and on the map.
                            </p>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-7">
                                <label class="form-label">Area</label>
                                <select name="location" class="form-select location-select" required>
                                    <option value="">Choose an area</option>
                                    <option value="CSUMB">CSUMB</option>
                                    <option value="Marina">Marina</option>
                                    <option value="Monterey">Monterey</option>
                                    <option value="Seaside">Seaside</option>
                                    <option value="Salinas">Salinas</option>
                                    <option value="Pacific Grove">Pacific Grove</option>
                                    <option value="Sand City">Sand City</option>
                                    <option value="Carmel">Carmel</option>
                                    <option value="Other Monterey County">Other Monterey County</option>
                                </select>
                            </div>

                            <div class="col-md-5">
                                <label class="form-label">Location Type</label>
                                <select name="location_type" class="form-select location-type-select">
                                    <option value="On-site">On-site</option>
                                    <option value="Remote">Remote</option>
                                    <option value="Hybrid">Hybrid</option>
                                </select>
                            </div>
                        </div>

                        <div class="location-hint-list">
                            <span class="location-hint-pill">Map Friendly</span>
                            <span class="location-hint-pill">Better Filtering</span>
                            <span class="location-hint-pill">Cleaner Listings</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Budget Text</label>
                    <input type="text" name="budget" class="form-control" placeholder="$50 - $100">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Budget Min</label>
                    <input type="number" step="0.01" name="budget_min" class="form-control">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Budget Max</label>
                    <input type="number" step="0.01" name="budget_max" class="form-control">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Deadline</label>
                    <input type="date" name="deadline" class="form-control">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Event Date</label>
                    <input type="date" name="event_date" class="form-control">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Image URL</label>
                    <input type="text" name="image_url" class="form-control">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Contact Email</label>
                    <input type="email" name="contact_email" class="form-control" value="<%= user.contact_email || '' %>">
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="beginner_friendly" value="1" id="beginnerFriendly">
                        <label class="form-check-label" for="beginnerFriendly">
                            Beginner Friendly
                        </label>
                    </div>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-form-primary">Post Gig</button>
                    <a href="/home" class="btn btn-form-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>