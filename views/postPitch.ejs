<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Post Pitch</title>
    <style>
        body {
            background: #f8f9fa;
        }

        .form-card {
            border: none;
            border-radius: 22px;
            box-shadow: 0 10px 24px rgba(0,0,0,0.08);
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">OtterGigs</a>

        <div class="d-flex align-items-center gap-2">
            <a href="/findPitch" class="btn btn-outline-light btn-sm">Find Pitch</a>
            <button class="btn btn-light btn-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#userMenuCanvas" aria-controls="userMenuCanvas">
                <%= user && (user.display_name || user.username) ? (user.display_name || user.username) : 'Menu' %>
            </button>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-5">
    <div class="card form-card">
        <div class="card-body p-4 p-md-5">
            <h1 class="fw-bold mb-3">Post a Pitch</h1>
            <p class="text-muted mb-4">Create a service listing so others can find your work.</p>

            <form action="/postPitch" method="POST" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Pitch Title</label>
                    <input type="text" name="title" class="form-control" required>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Service Name</label>
                    <input type="text" name="name" class="form-control" placeholder="Logo Design, Graduation Photos..." required>
                </div>

                <div class="col-12">
                    <label class="form-label">Bio / Description</label>
                    <textarea name="bio" class="form-control" rows="5" required></textarea>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select" required>
                        <option value="">Choose one</option>
                        <option value="Art">Art</option>
                        <option value="Music">Music</option>
                        <option value="Design">Design</option>
                        <option value="Photography">Photography</option>
                        <option value="Video">Video</option>
                        <option value="Writing">Writing</option>
                        <option value="Marketing">Marketing</option>
                        <option value="Misc">Misc</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Location Type</label>
                    <select name="location_type" class="form-select">
                        <option value="On-site">On-site</option>
                        <option value="Remote">Remote</option>
                        <option value="Hybrid">Hybrid</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Rate Type</label>
                    <select name="rate_type" class="form-select">
                        <option value="Fixed">Fixed</option>
                        <option value="Hourly">Hourly</option>
                        <option value="Negotiable">Negotiable</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Rate Min</label>
                    <input type="number" step="0.01" name="rate_min" class="form-control">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Rate Max</label>
                    <input type="number" step="0.01" name="rate_max" class="form-control">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Availability</label>
                    <input type="text" name="availability" class="form-control" placeholder="Weekends, Evenings, Flexible...">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Contact Email</label>
                    <input type="email" name="contact_email" class="form-control" value="<%= user.contact_email || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Portfolio Link</label>
                    <input type="text" name="portfolio" class="form-control" placeholder="https://...">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Image URL</label>
                    <input type="text" name="image_url" class="form-control">
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="beginner_friendly" value="1" id="beginnerFriendly">
                        <label class="form-check-label" for="beginnerFriendly">
                            Beginner Friendly
                        </label>
                    </div>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Post Pitch</button>
                    <a href="/home" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>