<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Gig Info</title>
    <style>
        .detail-card {
            border: none;
            border-radius: 22px;
            box-shadow: 0 10px 24px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .hero-img {
            width: 100%;
            max-height: 420px;
            object-fit: cover;
            background-color: #e9ecef;
        }

        .info-pill {
            display: inline-block;
            padding: 0.45rem 0.75rem;
            border-radius: 999px;
            margin-right: 0.4rem;
            margin-bottom: 0.4rem;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .poster-link {
            text-decoration: none;
            color: inherit;
        }

        .poster-link:hover {
            color: inherit;
        }

        .poster-avatar {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 50%;
        }

        .detail-sidebar {
            background: rgba(252, 252, 250, 0.74);
            border-radius: 22px;
            border: 1px solid rgba(110, 147, 160, 0.18);
            box-shadow: 0 10px 24px rgba(0,0,0,0.04);
        }
    </style>
</head>
<body class="page-detail page-theme-gig">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <div class="navbar-controls">
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: typeof user !== "undefined" && user ? user.profile_image_url : null }) %>
            <%- include("partials/navActions.ejs") %>
        </div>

        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-4">
    <div class="card detail-card">
        <img
            src="<%= gig.image_url && gig.image_url.trim() !== '' ? gig.image_url : 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=900&q=80' %>"
            alt="<%= gig.title %>"
            class="hero-img"
        >

        <div class="card-body p-4 p-md-5">
            <% const gigUrgencyLabel = gig.urgency || 'Open'; %>
            <% const gigUrgencyClass = gig.urgency === 'Urgent' ? 'gig-pill-urgent' : gig.urgency === 'High' ? 'gig-pill-high' : gig.urgency === 'Medium' ? 'gig-pill-medium' : 'gig-pill-low'; %>
            <% const gigStatusClass = gig.status === 'New' ? 'gig-pill-status-new' : gig.status === 'Filled' ? 'gig-pill-status-filled' : gig.status === 'Completed' ? 'gig-pill-status-completed' : gig.status === 'Closed' ? 'gig-pill-status-closed' : 'gig-pill-status-open'; %>
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h1 class="fw-bold mb-2"><%= gig.title %></h1>
                    <p class="text-muted mb-0">Posted by <strong><%= gig.display_name || gig.organization_name %></strong></p>
                </div>

                <div class="text-md-end">
                    <span class="info-pill theme-pill gig-pill-category"><%= gig.category || 'Misc' %></span>
                    <span class="info-pill theme-pill <%= gigUrgencyClass %>"><%= gigUrgencyLabel %></span>

                    <% if (gig.beginner_friendly) { %>
                        <span class="info-pill theme-pill gig-pill-beginner">Beginner Friendly</span>
                    <% } %>

                    <span class="info-pill theme-pill <%= gigStatusClass %>"><%= gig.status %></span>
                </div>
            </div>

            <hr class="my-4">

            <div class="row g-4">
                <div class="col-lg-8">
                    <h3 class="fw-bold mb-3">Gig Description</h3>
                    <p class="text-muted"><%= gig.description %></p>

                    <div class="mt-4">
                        <h4 class="fw-bold mb-3">Poster</h4>
                        <a href="/profile/<%= gig.user_id %>" class="poster-link">
                            <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-4 border">
                                <img
                                    src="<%= gig.profile_image_url && gig.profile_image_url.trim() !== '' ? gig.profile_image_url : 'https://via.placeholder.com/80x80?text=U' %>"
                                    alt="Poster"
                                    class="poster-avatar"
                                >
                                <div>
                                    <h5 class="mb-1"><%= gig.display_name || gig.organization_name || 'User' %></h5>
                                    <p class="text-muted mb-0"><%= gig.bio || 'View profile to learn more.' %></p>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="detail-sidebar p-4">
                        <h4 class="fw-bold mb-3">Gig Details</h4>

                        <p><strong>Looking For:</strong><br><span class="text-muted"><%= gig.looking_for %></span></p>
                        <p><strong>Location:</strong><br><span class="text-muted"><%= gig.location || 'N/A' %></span></p>
                        <p><strong>Location Type:</strong><br><span class="text-muted"><%= gig.location_type || 'N/A' %></span></p>
                        <p><strong>Budget:</strong><br><span class="text-muted"><%= gig.budget || 'Not listed' %></span></p>

                        <% if (gig.budget_min !== null && gig.budget_max !== null) { %>
                            <p><strong>Budget Range:</strong><br><span class="text-muted">$<%= gig.budget_min %> - $<%= gig.budget_max %></span></p>
                        <% } %>

                        <p><strong>Deadline:</strong><br><span class="text-muted"><%= gig.deadline ? new Date(gig.deadline).toLocaleDateString() : 'N/A' %></span></p>
                        <p><strong>Event Date:</strong><br><span class="text-muted"><%= gig.event_date ? new Date(gig.event_date).toLocaleDateString() : 'N/A' %></span></p>
                        <p><strong>Contact Email:</strong><br><span class="text-muted"><%= gig.contact_email || 'Not listed' %></span></p>

                        <div class="d-grid gap-2 mt-4">
                            <% if (!isSaved) { %>
                                <form action="/saveGig/<%= gig.id %>" method="POST">
                                    <button type="submit" class="btn btn-primary w-100">Save Gig</button>
                                </form>
                            <% } else { %>
                                <form action="/unsaveGig/<%= gig.id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-danger w-100">Remove Saved Gig</button>
                                </form>
                            <% } %>

                            <a href="mailto:<%= gig.contact_email %>?subject=Interested in: <%= gig.title %>" class="btn btn-outline-dark">
                                Contact Poster
                            </a>

                            <% if (isOwner) { %>
                                <a href="/updateGig/<%= gig.id %>" class="btn btn-warning">Update Gig</a>
                                <a href="/completeGig/<%= gig.id %>" class="btn btn-success">Mark Completed + Feedback</a>
                            <% } %>
                        </div>

                        <small class="text-muted d-block mt-3">
                            placeholder for something motivational or something....
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>
