<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Local Map</title>

    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""
    />
</head>
<body class="page-map-view">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>

        <div class="navbar-controls">
            <%- include("partials/navActions.ejs") %>
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: user && user.profile_image_url }) %>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-4">
    <div class="page-header mb-4">
        <h1 class="fw-bold mb-2">OtterGigs Local Map</h1>
        <p class="mb-0">
            Explore open gigs and pitches around Monterey County. Use the toggle to switch views and click a marker to jump into the listings.
        </p>
    </div>

    <div class="card map-panel-card border-0 shadow-sm rounded-4">
        <div class="card-body p-3 p-md-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                <div>
                    <h4 class="fw-bold mb-1">Map View</h4>
                    <p class="text-muted mb-0">Pins show how many open listings are in each area.</p>
                </div>

                <div class="map-toggle-group" role="group" aria-label="Map type toggle">
                    <button type="button" class="btn btn-map-toggle active" data-map-type="gig">Show Gigs</button>
                    <button type="button" class="btn btn-map-toggle" data-map-type="pitch">Show Pitches</button>
                </div>
            </div>

            <div class="map-legend mb-3">
                <span class="map-legend-pill">Monterey County Focus</span>
                <span class="map-legend-pill">Open Listings Only</span>
                <span class="map-legend-pill">Click Pins for Details</span>
            </div>

            <div id="localMap" class="local-map-frame rounded-4"></div>
        </div>
    </div>
</div>

<script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
></script>
<script src="/js/localMap.js"></script>
</body>
</html>