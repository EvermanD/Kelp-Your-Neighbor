<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Find Pitch</title>
</head>
<body class="page-find-pitch">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <div class="navbar-controls">
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: user && user.profile_image_url }) %>
            <%- include("partials/navActions.ejs") %>
        </div>

        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container page-section-shell">
    <div class="page-header page-hero-spacing">
        <h1 class="fw-bold mb-2">Find a Pitch</h1>
        <p class="mb-0">Browse creators, services, and skill offerings from students and locals.</p>
    </div>

    <% if (highlightPitches && highlightPitches.length > 0) { %>
        <section class="spotlight-strip spotlight-strip-pitch mb-4" aria-labelledby="pitch-spotlight-title">
            <div class="spotlight-strip-head">
                <div>
                    <p class="spotlight-strip-eyebrow mb-1">Smart highlights</p>
                    <h2 id="pitch-spotlight-title" class="spotlight-strip-title mb-0">What to check first</h2>
                </div>

                <div class="spotlight-strip-controls">
                    <button type="button" class="spotlight-strip-control" data-spotlight-prev aria-label="Previous highlight">&larr;</button>
                    <button type="button" class="spotlight-strip-control" data-spotlight-next aria-label="Next highlight">&rarr;</button>
                </div>
            </div>

            <div class="spotlight-strip-carousel" data-spotlight-carousel>
                <div class="spotlight-strip-track" data-spotlight-track>
                    <% highlightPitches.forEach((item) => { %>
                        <article class="spotlight-strip-card" data-spotlight-card>
                            <img
                                src="<%= item.image_url && item.image_url.trim() !== '' ? item.image_url : 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=900&q=80' %>"
                                alt="<%= item.title %>"
                                class="spotlight-strip-image"
                            >

                            <div class="spotlight-strip-overlay"></div>

                            <div class="spotlight-strip-content">
                                <span class="spotlight-strip-badge"><%= item.label %></span>
                                <h3 class="spotlight-strip-card-title"><%= item.title %></h3>
                                <p class="spotlight-strip-meta mb-1"><%= item.category || 'Misc' %> • <%= item.location || 'Local' %></p>
                                <p class="spotlight-strip-description mb-3"><%= item.description %></p>
                                <p class="spotlight-strip-saves mb-3"><strong><%= item.save_count || 0 %></strong> save<%= Number(item.save_count || 0) === 1 ? '' : 's' %></p>
                                <a href="/pitchInfo/<%= item.id %>" class="btn btn-sm btn-light">View Pitch</a>
                            </div>
                        </article>
                    <% }) %>
                </div>
            </div>
        </section>
    <% } %>

    <div class="card filter-card mb-4">
        <div class="card-body">
            <form action="/findPitch" method="GET" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" class="form-control" placeholder="Title, skill, service, bio..." value="<%= filters.search %>">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All</option>
                        <option value="Art" <%= filters.category === 'Art' ? 'selected' : '' %>>Art</option>
                        <option value="Music" <%= filters.category === 'Music' ? 'selected' : '' %>>Music</option>
                        <option value="Design" <%= filters.category === 'Design' ? 'selected' : '' %>>Design</option>
                        <option value="Photography" <%= filters.category === 'Photography' ? 'selected' : '' %>>Photography</option>
                        <option value="Video" <%= filters.category === 'Video' ? 'selected' : '' %>>Video</option>
                        <option value="Writing" <%= filters.category === 'Writing' ? 'selected' : '' %>>Writing</option>
                        <option value="Marketing" <%= filters.category === 'Marketing' ? 'selected' : '' %>>Marketing</option>
                        <option value="Misc" <%= filters.category === 'Misc' ? 'selected' : '' %>>Misc</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" placeholder="Campus, Monterey..." value="<%= filters.location %>">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Beginner Friendly</label>
                    <select name="beginner" class="form-select">
                        <option value="">All</option>
                        <option value="1" <%= filters.beginner === '1' ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-filter-primary">Search / Filter</button>
                    <a href="/findPitch" class="btn btn-filter-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <% if (!pitches || pitches.length === 0) { %>
        <div class="alert alert-info rounded-4">
            No open pitches matched your filters.
        </div>
    <% } %>

    <div class="row g-4 pitches-grid">
        <% pitches.forEach(pitch => { %>
            <div class="col-md-6 col-lg-4">
                <div
                    class="card pitch-card h-100"
                    onclick="if (!event.target.closest('a, button')) window.location.href='/pitchInfo/<%= pitch.id %>';"
                    style="cursor: pointer;"
                >
                    <img
                        src="<%= pitch.image_url && pitch.image_url.trim() !== '' ? pitch.image_url : 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=900&q=80' %>"
                        alt="<%= pitch.title %>"
                        class="pitch-image"
                    >

                    <div class="card-body d-flex flex-column">
                        <% const pitchCategory = (pitch.category || 'Misc').toLowerCase(); %>
                        <% const pitchCategoryClass = pitchCategory === 'design' ? 'pitch-pill-design' : pitchCategory === 'photography' || pitchCategory === 'video' ? 'pitch-pill-photography' : pitchCategory === 'marketing' || pitchCategory === 'writing' ? 'pitch-pill-marketing' : 'pitch-pill-default'; %>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="theme-pill <%= pitchCategoryClass %>"><%= pitch.category || 'Misc' %></span>
                            <% if (pitch.rate_type) { %>
                                <span class="theme-pill pitch-pill-rate"><%= pitch.rate_type %></span>
                            <% } %>
                            <% if (pitch.beginner_friendly) { %>
                                <span class="theme-pill pitch-pill-beginner">Beginner Friendly</span>
                            <% } else { %>
                                <span class="theme-pill pitch-pill-open">Open</span>
                            <% } %>
                        </div>

                        <h4 class="card-title fw-bold mb-3"><%= pitch.title %></h4>
                        <p class="card-meta mb-1"><strong>Service:</strong> <%= pitch.name %></p>
                        <p class="card-meta mb-1"><strong>Location:</strong> <%= pitch.location || 'N/A' %> <%= pitch.location_type ? '(' + pitch.location_type + ')' : '' %></p>
                        <p class="card-meta mb-1"><strong>Rate Type:</strong> <%= pitch.rate_type || 'Not listed' %></p>

                        <% if (pitch.rate_min !== null && pitch.rate_max !== null) { %>
                            <p class="card-meta mb-1"><strong>Rate Range:</strong> $<%= pitch.rate_min %> - $<%= pitch.rate_max %></p>
                        <% } else { %>
                            <p class="card-meta mb-1"><strong>Availability:</strong> <%= pitch.availability || 'Not listed' %></p>
                        <% } %>
                        <p class="card-meta mb-3"><strong>Saves:</strong> <%= pitch.save_count || 0 %></p>

                        <div class="card-description-panel mb-3">
                            <p class="mb-0 description-text">
                                <%= pitch.bio.length > 120 ? pitch.bio.substring(0, 120) + '...' : pitch.bio %>
                            </p>
                        </div>

                        <div class="mt-auto d-flex justify-content-between align-items-center gap-2 flex-wrap">
                            <a href="/profile/<%= pitch.user_id %>" class="poster-chip">
                                <img
                                    src="<%= pitch.profile_image_url && pitch.profile_image_url.trim() !== '' ? pitch.profile_image_url : 'https://via.placeholder.com/40x40?text=U' %>"
                                    alt="Creator"
                                    class="poster-avatar"
                                >
                                <small class="fw-semibold"><%= pitch.display_name || pitch.name || 'User' %></small>
                            </a>

                            <a href="/pitchInfo/<%= pitch.id %>" class="btn btn-card-cta btn-sm">View Full Pitch</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const carousels = document.querySelectorAll("[data-spotlight-carousel]");

    carousels.forEach((carousel) => {
        const track = carousel.querySelector("[data-spotlight-track]");
        const cards = Array.from(carousel.querySelectorAll("[data-spotlight-card]"));
        const section = carousel.closest(".spotlight-strip");
        const prevButton = section?.querySelector("[data-spotlight-prev]");
        const nextButton = section?.querySelector("[data-spotlight-next]");

        if (!track || cards.length === 0 || !prevButton || !nextButton) {
            return;
        }

        let currentIndex = 0;
        let autoplayTimer = null;

        function updatePosition() {
            track.style.transform = `translateX(-${currentIndex * 100}%)`;
        }

        function goTo(index) {
            if (index < 0) {
                currentIndex = cards.length - 1;
            } else if (index >= cards.length) {
                currentIndex = 0;
            } else {
                currentIndex = index;
            }

            updatePosition();
        }

        function startAutoplay() {
            if (cards.length <= 1) {
                return;
            }

            autoplayTimer = window.setInterval(() => {
                goTo(currentIndex + 1);
            }, 4200);
        }

        function stopAutoplay() {
            if (autoplayTimer) {
                window.clearInterval(autoplayTimer);
                autoplayTimer = null;
            }
        }

        prevButton.addEventListener("click", () => goTo(currentIndex - 1));
        nextButton.addEventListener("click", () => goTo(currentIndex + 1));

        section.addEventListener("mouseenter", stopAutoplay);
        section.addEventListener("mouseleave", startAutoplay);

        updatePosition();
        startAutoplay();
    });
});
</script>

</body>
</html>
