<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Find Pitch</title>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .page-header {
            background: linear-gradient(135deg, #6f42c1, #0dcaf0);
            color: white;
            border-radius: 22px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 24px rgba(0,0,0,0.1);
        }

        .filter-card,
        .pitch-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

        .pitch-card {
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            height: 100%;
        }

        .pitch-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 30px rgba(0,0,0,0.12);
        }

        .pitch-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #e9ecef;
        }

        .poster-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
            color: inherit;
        }

        .poster-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #fff;
        }

        .nav-profile-btn {
            width: 42px;
            height: 42px;
            padding: 0;
            border-radius: 50%;
            overflow: hidden;
            border: none;
            background: transparent;
        }

        .nav-profile-btn img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid white;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">OtterGigs</a>

        <div class="d-flex align-items-center gap-2">
            <a href="/home" class="btn btn-outline-light btn-sm">Home</a>

            <button class="nav-profile-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#userMenuCanvas" aria-controls="userMenuCanvas">
                <img
                    src="<%= user && user.profile_image_url && user.profile_image_url.trim() !== '' ? user.profile_image_url : 'https://via.placeholder.com/80x80?text=U' %>"
                    alt="Profile"
                >
            </button>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-4">
    <div class="page-header">
        <h1 class="fw-bold mb-2">Find a Pitch</h1>
        <p class="mb-0">Browse creators, services, and skill offerings from students and locals.</p>
    </div>

    <div class="card filter-card mb-4">
        <div class="card-body">
            <form action="/findPitch" method="GET" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" class="form-control" placeholder="Title, skill, service, bio..." value="<%= filters.search %>">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All</option>
                        <option value="Art" <%= filters.category === 'Art' ? 'selected' : '' %>>Art</option>
                        <option value="Music" <%= filters.category === 'Music' ? 'selected' : '' %>>Music</option>
                        <option value="Design" <%= filters.category === 'Design' ? 'selected' : '' %>>Design</option>
                        <option value="Photography" <%= filters.category === 'Photography' ? 'selected' : '' %>>Photography</option>
                        <option value="Video" <%= filters.category === 'Video' ? 'selected' : '' %>>Video</option>
                        <option value="Writing" <%= filters.category === 'Writing' ? 'selected' : '' %>>Writing</option>
                        <option value="Marketing" <%= filters.category === 'Marketing' ? 'selected' : '' %>>Marketing</option>
                        <option value="Misc" <%= filters.category === 'Misc' ? 'selected' : '' %>>Misc</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" placeholder="Campus, Monterey..." value="<%= filters.location %>">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Beginner Friendly</label>
                    <select name="beginner" class="form-select">
                        <option value="">All</option>
                        <option value="1" <%= filters.beginner === '1' ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Search / Filter</button>
                    <a href="/findPitch" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <% if (!pitches || pitches.length === 0) { %>
        <div class="alert alert-info rounded-4">
            No open pitches matched your filters.
        </div>
    <% } %>

    <div class="row g-4">
        <% pitches.forEach(pitch => { %>
            <div class="col-md-6 col-lg-4">
                <div class="card pitch-card">
                    <img
                        src="<%= pitch.image_url && pitch.image_url.trim() !== '' ? pitch.image_url : 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=900&q=80' %>"
                        alt="<%= pitch.title %>"
                        class="pitch-image"
                    >

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary"><%= pitch.category || 'Misc' %></span>

                            <% if (pitch.beginner_friendly) { %>
                                <span class="badge bg-success">Beginner Friendly</span>
                            <% } else { %>
                                <span class="badge bg-secondary">Open</span>
                            <% } %>
                        </div>

                        <h4 class="card-title fw-bold mb-1"><%= pitch.title %></h4>
                        <p class="text-muted mb-1"><strong>Service:</strong> <%= pitch.name %></p>
                        <p class="text-muted mb-1"><strong>Location:</strong> <%= pitch.location || 'N/A' %> <%= pitch.location_type ? '(' + pitch.location_type + ')' : '' %></p>
                        <p class="text-muted mb-1"><strong>Rate Type:</strong> <%= pitch.rate_type || 'Not listed' %></p>

                        <% if (pitch.rate_min !== null && pitch.rate_max !== null) { %>
                            <p class="text-muted mb-3"><strong>Rate Range:</strong> $<%= pitch.rate_min %> - $<%= pitch.rate_max %></p>
                        <% } else { %>
                            <p class="text-muted mb-3"><strong>Availability:</strong> <%= pitch.availability || 'Not listed' %></p>
                        <% } %>

                        <p class="text-muted">
                            <%= pitch.bio.length > 120 ? pitch.bio.substring(0, 120) + '...' : pitch.bio %>
                        </p>

                        <div class="mt-auto d-flex justify-content-between align-items-center gap-2 flex-wrap">
                            <a href="/profile/<%= pitch.user_id %>" class="poster-chip">
                                <img
                                    src="<%= pitch.profile_image_url && pitch.profile_image_url.trim() !== '' ? pitch.profile_image_url : 'https://via.placeholder.com/40x40?text=U' %>"
                                    alt="Creator"
                                    class="poster-avatar"
                                >
                                <small class="fw-semibold"><%= pitch.display_name || pitch.name || 'User' %></small>
                            </a>

                            <a href="/pitchInfo/<%= pitch.id %>" class="btn btn-dark btn-sm">View Full Pitch</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>