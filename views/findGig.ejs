<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title><img src="/js/logo.png" alt="OtterGigs" class="site-logo" />
 | Find a Gig</title>
    <style>
        body {
            background-color: #E6F3FF;
        }

        .page-header {
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: white;
            border-radius: 18px;
            padding: 2rem;
            margin-bottom: 2rem;
        }

        .filter-card,
        .gig-card {
            border: 3px solid navy;
            border-radius: 18px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.15);
        }

        .gig-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            overflow: hidden;
            height: 100%;
        }

        .gig-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 28px rgba(0,0,0,0.12);
        }

        .gig-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background-color: #e9ecef;
        }

        .badge-soft {
            font-size: 0.8rem;
            padding: 0.45rem 0.7rem;
            border-radius: 999px;
            font-weight: 500;
        }

        .desc-preview {
            min-height: 72px;
            line-height: 1.6;
            font-weight: 400;
            background-color: #F0E6FA;
            padding: 0.75rem;
            border-radius: 8px;
        }

        .meta-text {
            font-size: 0.95rem;
            color: #6c757d;
            font-weight: 500;
            line-height: 1.5;
        }

        .card-title {
            font-weight: 600 !important;
            line-height: 1.4;
            letter-spacing: -0.3px;
        }

        .page-header h1 {
            font-weight: 600;
            line-height: 1.3;
            letter-spacing: -0.5px;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-light navbar-custom">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home"><img src="/js/logo.png" alt="OtterGigs" class="site-logo" /></a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/home">Return to Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="/findGig">Find Gig</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/postGig">Post Gig</a>
                </li>
            </ul>
            <a href="/logout" class="btn btn-outline-light">Logout</a>
        </div>
    </div>
</nav>

<div class="container py-4">
    <div class="page-header">
        <h1 class="fw-bold mb-2">Find Your Next Gig</h1>
        <p class="mb-0">Browse local creative opportunities and open the ones that match your skills.</p>
        <div class="moving-text">
            <strong>✨ Trending Now:</strong> Art • Music • Design • Photography | <strong>⏰ Urgent Gigs Available</strong> | <strong>🌟 Beginner Friendly Options</strong>
        </div>
    </div>

    <div class="card filter-card mb-4">
        <div class="card-body">
            <form action="/findGig" method="GET" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        placeholder="Title, category, role, organization..."
                        value="<%= filters.search %>"
                    >
                </div>

                <div class="col-md-2">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All</option>
                        <option value="Art" <%= filters.category === 'Art' ? 'selected' : '' %>>Art</option>
                        <option value="Music" <%= filters.category === 'Music' ? 'selected' : '' %>>Music</option>
                        <option value="Design" <%= filters.category === 'Design' ? 'selected' : '' %>>Design</option>
                        <option value="Photography" <%= filters.category === 'Photography' ? 'selected' : '' %>>Photography</option>
                        <option value="Video" <%= filters.category === 'Video' ? 'selected' : '' %>>Video</option>
                        <option value="Writing" <%= filters.category === 'Writing' ? 'selected' : '' %>>Writing</option>
                        <option value="Marketing" <%= filters.category === 'Marketing' ? 'selected' : '' %>>Marketing</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Location</label>
                    <input
                        type="text"
                        name="location"
                        class="form-control"
                        placeholder="Campus, Downtown..."
                        value="<%= filters.location %>"
                    >
                </div>

                <div class="col-md-2">
                    <label class="form-label">Urgency</label>
                    <select name="urgency" class="form-select">
                        <option value="">All</option>
                        <option value="Low" <%= filters.urgency === 'Low' ? 'selected' : '' %>>Low</option>
                        <option value="Medium" <%= filters.urgency === 'Medium' ? 'selected' : '' %>>Medium</option>
                        <option value="High" <%= filters.urgency === 'High' ? 'selected' : '' %>>High</option>
                        <option value="Urgent" <%= filters.urgency === 'Urgent' ? 'selected' : '' %>>Urgent</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Beginner Friendly</label>
                    <select name="beginner" class="form-select">
                        <option value="">All</option>
                        <option value="1" <%= filters.beginner === '1' ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>

                <div class="col-12 d-flex gap-3">
                    <button type="submit" class="btn btn-primary">Search / Filter</button>
                    <a href="/findGig" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <% if (gigs.length === 0) { %>
        <div class="alert alert-info rounded-4">
            No gigs matched your search yet.
        </div>
    <% } %>

    <div class="row g-4">
        <% gigs.forEach(gig => { %>
            <div class="col-md-4">
                <div class="card gig-card">
                    <img
                        src="<%= gig.image_url && gig.image_url.trim() !== '' ? gig.image_url : 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=900&q=80' %>"
                        alt="<%= gig.title %>"
                        class="gig-image"
                    >

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary badge-soft"><%= gig.category %></span>

                            <% if (gig.urgency === 'Urgent') { %>
                                <span class="badge bg-danger badge-soft"><%= gig.urgency %></span>
                            <% } else if (gig.urgency === 'High') { %>
                                <span class="badge bg-warning badge-soft"><%= gig.urgency %></span>
                            <% } else { %>
                                <span class="badge bg-secondary badge-soft"><%= gig.urgency %></span>
                            <% } %>
                        </div>

                        <h4 class="card-title fw-bold"><%= gig.title %></h4>

                        <p class="meta-text mb-1"><strong>Looking for:</strong> <%= gig.looking_for %></p>
                        <p class="meta-text mb-1"><strong>Location:</strong> <%= gig.location %> (<%= gig.location_type %>)</p>
                        <p class="meta-text mb-1"><strong>Budget:</strong> <%= gig.budget %></p>
                        <p class="meta-text mb-3"><strong>Deadline:</strong> <%= gig.deadline ? new Date(gig.deadline).toLocaleDateString() : 'N/A' %></p>

                        <% if (gig.beginner_friendly) { %>
                            <div class="mb-3">
                                <span class="badge bg-success badge-soft">Beginner Friendly</span>
                            </div>
                        <% } %>

                        <p class="card-text desc-preview text-muted">
                            <%= gig.description.length > 120 ? gig.description.substring(0, 120) + '...' : gig.description %>
                        </p>

                        <div class="mt-auto">
                            <a href="/gigInfo/<%= gig.id %>" class="btn btn-dark w-100">View Full Gig</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
</body>
</html>