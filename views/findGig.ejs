<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Find Gig</title>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .page-header {
            background: linear-gradient(135deg, #0d6efd, #20c997);
            color: white;
            border-radius: 22px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 24px rgba(0,0,0,0.1);
        }

        .filter-card,
        .gig-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

        .gig-card {
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            height: 100%;
        }

        .gig-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 30px rgba(0,0,0,0.12);
        }

        .gig-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #e9ecef;
        }

        .poster-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
            color: inherit;
        }

        .poster-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #fff;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">OtterGigs</a>

        <div class="d-flex align-items-center gap-2">
            <a href="/home" class="btn btn-outline-light btn-sm">Home</a>
            <button class="btn btn-light btn-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#userMenuCanvas" aria-controls="userMenuCanvas">
                <%= user && (user.display_name || user.username) ? (user.display_name || user.username) : 'Menu' %>
            </button>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-4">
    <div class="page-header">
        <h1 class="fw-bold mb-2">Find Your Next Gig</h1>
        <p class="mb-0">Browse open community opportunities and filter the ones that match your skills.</p>
    </div>

    <div class="card filter-card mb-4">
        <div class="card-body">
            <form action="/findGig" method="GET" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" class="form-control" placeholder="Title, role, organization..." value="<%= filters.search %>">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All</option>
                        <option value="Art" <%= filters.category === 'Art' ? 'selected' : '' %>>Art</option>
                        <option value="Music" <%= filters.category === 'Music' ? 'selected' : '' %>>Music</option>
                        <option value="Design" <%= filters.category === 'Design' ? 'selected' : '' %>>Design</option>
                        <option value="Photography" <%= filters.category === 'Photography' ? 'selected' : '' %>>Photography</option>
                        <option value="Video" <%= filters.category === 'Video' ? 'selected' : '' %>>Video</option>
                        <option value="Writing" <%= filters.category === 'Writing' ? 'selected' : '' %>>Writing</option>
                        <option value="Marketing" <%= filters.category === 'Marketing' ? 'selected' : '' %>>Marketing</option>
                        <option value="Misc" <%= filters.category === 'Misc' ? 'selected' : '' %>>Misc</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" placeholder="Campus, Downtown..." value="<%= filters.location %>">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Urgency</label>
                    <select name="urgency" class="form-select">
                        <option value="">All</option>
                        <option value="Low" <%= filters.urgency === 'Low' ? 'selected' : '' %>>Low</option>
                        <option value="Medium" <%= filters.urgency === 'Medium' ? 'selected' : '' %>>Medium</option>
                        <option value="High" <%= filters.urgency === 'High' ? 'selected' : '' %>>High</option>
                        <option value="Urgent" <%= filters.urgency === 'Urgent' ? 'selected' : '' %>>Urgent</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Beginner Friendly</label>
                    <select name="beginner" class="form-select">
                        <option value="">All</option>
                        <option value="1" <%= filters.beginner === '1' ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Search / Filter</button>
                    <a href="/findGig" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <% if (!gigs || gigs.length === 0) { %>
        <div class="alert alert-info rounded-4">
            No open gigs matched your filters.
        </div>
    <% } %>

    <div class="row g-4">
        <% gigs.forEach(gig => { %>
            <div class="col-md-6 col-lg-4">
                <div class="card gig-card">
                    <img
                        src="<%= gig.image_url && gig.image_url.trim() !== '' ? gig.image_url : 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=900&q=80' %>"
                        alt="<%= gig.title %>"
                        class="gig-image"
                    >

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary"><%= gig.category || 'Misc' %></span>

                            <% if (gig.urgency === 'Urgent') { %>
                                <span class="badge bg-danger"><%= gig.urgency %></span>
                            <% } else if (gig.urgency === 'High') { %>
                                <span class="badge bg-warning text-dark"><%= gig.urgency %></span>
                            <% } else { %>
                                <span class="badge bg-secondary"><%= gig.urgency %></span>
                            <% } %>
                        </div>

                        <h4 class="card-title fw-bold"><%= gig.title %></h4>

                        <p class="text-muted mb-1"><strong>Looking for:</strong> <%= gig.looking_for %></p>
                        <p class="text-muted mb-1"><strong>Location:</strong> <%= gig.location %> <%= gig.location_type ? '(' + gig.location_type + ')' : '' %></p>
                        <p class="text-muted mb-1"><strong>Budget:</strong> <%= gig.budget || 'Not listed' %></p>
                        <p class="text-muted mb-3"><strong>Deadline:</strong> <%= gig.deadline ? new Date(gig.deadline).toLocaleDateString() : 'N/A' %></p>

                        <% if (gig.beginner_friendly) { %>
                            <div class="mb-3">
                                <span class="badge bg-success">Beginner Friendly</span>
                            </div>
                        <% } %>

                        <p class="text-muted">
                            <%= gig.description.length > 120 ? gig.description.substring(0, 120) + '...' : gig.description %>
                        </p>

                        <div class="mt-auto d-flex justify-content-between align-items-center gap-2 flex-wrap">
                            <a href="/profile/<%= gig.user_id %>" class="poster-chip">
                                <img
                                    src="<%= gig.profile_image_url && gig.profile_image_url.trim() !== '' ? gig.profile_image_url : 'https://via.placeholder.com/40x40?text=U' %>"
                                    alt="Poster"
                                    class="poster-avatar"
                                >
                                <small class="fw-semibold"><%= gig.display_name || gig.organization_name || 'User' %></small>
                            </a>

                            <a href="/gigInfo/<%= gig.id %>" class="btn btn-dark btn-sm">View Full Gig</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>