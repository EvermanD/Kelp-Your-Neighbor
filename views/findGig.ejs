<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Find Gig</title>
</head>
<body class="page-find-gig">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>

        <div class="navbar-controls">
            <%- include("partials/navActions.ejs") %>
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: user && user.profile_image_url }) %>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-4">
    <div class="page-header">
        <h1 class="fw-bold mb-2">Find Your Next Gig</h1>
        <p class="mb-0">Browse open community opportunities and filter the ones that match your skills.</p>
    </div>

    <div class="card filter-card mb-4">
        <div class="card-body">
            <form action="/findGig" method="GET" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" class="form-control" placeholder="Title, role, organization..." value="<%= filters.search %>">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All</option>
                        <option value="Art" <%= filters.category === 'Art' ? 'selected' : '' %>>Art</option>
                        <option value="Music" <%= filters.category === 'Music' ? 'selected' : '' %>>Music</option>
                        <option value="Design" <%= filters.category === 'Design' ? 'selected' : '' %>>Design</option>
                        <option value="Photography" <%= filters.category === 'Photography' ? 'selected' : '' %>>Photography</option>
                        <option value="Video" <%= filters.category === 'Video' ? 'selected' : '' %>>Video</option>
                        <option value="Writing" <%= filters.category === 'Writing' ? 'selected' : '' %>>Writing</option>
                        <option value="Marketing" <%= filters.category === 'Marketing' ? 'selected' : '' %>>Marketing</option>
                        <option value="Misc" <%= filters.category === 'Misc' ? 'selected' : '' %>>Misc</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" placeholder="Campus, Downtown..." value="<%= filters.location %>">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Urgency</label>
                    <select name="urgency" class="form-select">
                        <option value="">All</option>
                        <option value="Low" <%= filters.urgency === 'Low' ? 'selected' : '' %>>Low</option>
                        <option value="Medium" <%= filters.urgency === 'Medium' ? 'selected' : '' %>>Medium</option>
                        <option value="High" <%= filters.urgency === 'High' ? 'selected' : '' %>>High</option>
                        <option value="Urgent" <%= filters.urgency === 'Urgent' ? 'selected' : '' %>>Urgent</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Beginner Friendly</label>
                    <select name="beginner" class="form-select">
                        <option value="">All</option>
                        <option value="1" <%= filters.beginner === '1' ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-filter-primary">Search / Filter</button>
                    <a href="/findGig" class="btn btn-filter-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <% if (!gigs || gigs.length === 0) { %>
        <div class="alert alert-info rounded-4">
            No open gigs matched your filters.
        </div>
    <% } %>

    <div class="row g-4 gigs-grid">
        <% gigs.forEach(gig => { %>
            <div class="col-md-6 col-lg-4">
                <div
                    class="card gig-card h-100"
                    onclick="if (!event.target.closest('a, button')) window.location.href='/gigInfo/<%= gig.id %>';"
                    style="cursor: pointer;"
                >
                    <img
                        src="<%= gig.image_url && gig.image_url.trim() !== '' ? gig.image_url : 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=900&q=80' %>"
                        alt="<%= gig.title %>"
                        class="gig-image"
                    >

                    <div class="card-body d-flex flex-column">
                        <% const gigUrgencyLabel = gig.urgency || 'Open'; %>
                        <% const gigUrgencyClass = gig.urgency === 'Urgent' ? 'gig-pill-urgent' : gig.urgency === 'High' ? 'gig-pill-high' : gig.urgency === 'Medium' ? 'gig-pill-medium' : 'gig-pill-low'; %>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="theme-pill gig-pill-category"><%= gig.category || 'Misc' %></span>
                            <span class="theme-pill <%= gigUrgencyClass %>"><%= gigUrgencyLabel %></span>
                            <% if (gig.beginner_friendly) { %>
                                <span class="theme-pill gig-pill-beginner">Beginner Friendly</span>
                            <% } %>
                        </div>

                        <h4 class="card-title fw-bold mb-3"><%= gig.title %></h4>

                        <p class="card-meta mb-1"><strong>Looking for:</strong> <%= gig.looking_for %></p>
                        <p class="card-meta mb-1"><strong>Location:</strong> <%= gig.location %> <%= gig.location_type ? '(' + gig.location_type + ')' : '' %></p>
                        <p class="card-meta mb-1"><strong>Budget:</strong> <%= gig.budget || 'Not listed' %></p>
                        <p class="card-meta mb-3"><strong>Deadline:</strong> <%= gig.deadline ? new Date(gig.deadline).toLocaleDateString() : 'N/A' %></p>

                        <div class="card-description-panel mb-3">
                            <p class="mb-0 description-text">
                                <%= gig.description.length > 120 ? gig.description.substring(0, 120) + '...' : gig.description %>
                            </p>
                        </div>

                        <div class="mt-auto d-flex justify-content-between align-items-center gap-2 flex-wrap">
                            <a href="/profile/<%= gig.user_id %>" class="poster-chip">
                                <img
                                    src="<%= gig.profile_image_url && gig.profile_image_url.trim() !== '' ? gig.profile_image_url : 'https://via.placeholder.com/40x40?text=U' %>"
                                    alt="Poster"
                                    class="poster-avatar"
                                >
                                <small class="fw-semibold"><%= gig.display_name || gig.organization_name || 'User' %></small>
                            </a>

                            <a href="/gigInfo/<%= gig.id %>" class="btn btn-card-cta btn-sm">View Full Gig</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

</body>
</html>
