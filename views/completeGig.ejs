<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>Complete Gig</title>
</head>
<body class="bg-light">
<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">
            <h1 class="fw-bold mb-3">Mark Gig as Completed</h1>
            <p class="text-muted mb-4">
                Choose the user who completed "<strong><%= gig.title %></strong>" and leave feedback.
            </p>

            <form action="/completeGig/<%= gig.id %>" method="POST" class="row g-3">
                <div class="col-12">
                    <label for="gigUserSearch" class="form-label">Search by display name</label>
                    <input
                        type="text"
                        id="gigUserSearch"
                        class="form-control mb-3"
                        placeholder="Start typing a display name..."
                    >

                    <label class="form-label">Who completed this gig?</label>
                    <select name="completed_user_id" id="gigCompletedUserSelect" class="form-select" required size="8">
                        <option value="">Choose a user</option>
                        <% users.forEach(person => { %>
                            <% const visibleName = person.display_name && person.display_name.trim() !== '' ? person.display_name : person.username; %>
                            <option
                                value="<%= person.id %>"
                                data-display-name="<%= visibleName.toLowerCase() %>"
                            >
                                <%= visibleName %> (<%= person.profile_type %>)<%= person.saved_this_gig ? ' — Saved this gig' : '' %>
                            </option>
                        <% }) %>
                    </select>
                    <div class="form-text">
                        Users who saved this gig are listed first.
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label">Feedback / Praise</label>
                    <textarea name="feedback" class="form-control" rows="5" placeholder="They did an amazing job, communicated well, and delivered on time."></textarea>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-success">Complete Gig</button>
                    <a href="/gigInfo/<%= gig.id %>" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const gigUserSearch = document.getElementById('gigUserSearch');
    const gigCompletedUserSelect = document.getElementById('gigCompletedUserSelect');

    gigUserSearch.addEventListener('input', function () {
        const searchValue = this.value.trim().toLowerCase();
        const options = gigCompletedUserSelect.querySelectorAll('option');

        options.forEach((option, index) => {
            if (index === 0) {
                option.hidden = false;
                return;
            }

            const displayName = option.dataset.displayName || '';
            option.hidden = searchValue !== '' && !displayName.includes(searchValue);
        });
    });
</script>
</body>
</html>