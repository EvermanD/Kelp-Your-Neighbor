<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Pitch Info</title>
    <style>
        .detail-card {
            border: none;
            border-radius: 22px;
            box-shadow: 0 10px 24px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .hero-img {
            width: 100%;
            max-height: 420px;
            object-fit: cover;
            background-color: #e9ecef;
        }

        .info-pill {
            display: inline-block;
            padding: 0.45rem 0.75rem;
            border-radius: 999px;
            margin-right: 0.4rem;
            margin-bottom: 0.4rem;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .creator-link {
            text-decoration: none;
            color: inherit;
        }

        .creator-link:hover {
            color: inherit;
        }

        .creator-avatar {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 50%;
        }
    </style>
</head>
<body class="page-find-pitch">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>

        <div class="navbar-controls">
            <%- include("partials/navActions.ejs") %>
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: user && user.profile_image_url }) %>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-4">
    <div class="card detail-card">
        <img
            src="<%= pitch.image_url && pitch.image_url.trim() !== '' ? pitch.image_url : 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=900&q=80' %>"
            alt="<%= pitch.title %>"
            class="hero-img"
        >

        <div class="card-body p-4 p-md-5">
            <% const pitchCategory = (pitch.category || 'Misc').toLowerCase(); %>
            <% const pitchCategoryClass = pitchCategory === 'design' ? 'pitch-pill-design' : pitchCategory === 'photography' || pitchCategory === 'video' ? 'pitch-pill-photography' : pitchCategory === 'marketing' || pitchCategory === 'writing' ? 'pitch-pill-marketing' : 'pitch-pill-default'; %>
            <% const pitchStatusClass = pitch.status === 'Open' ? 'pitch-pill-open' : 'pitch-pill-default'; %>
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h1 class="fw-bold mb-2"><%= pitch.title %></h1>
                    <p class="text-muted mb-0">Offered by <strong><%= pitch.display_name || pitch.name %></strong></p>
                </div>

                <div class="text-md-end">
                    <span class="theme-pill info-pill <%= pitchCategoryClass %>"><%= pitch.category || 'Misc' %></span>

                    <% if (pitch.rate_type) { %>
                        <span class="theme-pill info-pill pitch-pill-rate"><%= pitch.rate_type %></span>
                    <% } %>

                    <% if (pitch.beginner_friendly) { %>
                        <span class="theme-pill info-pill pitch-pill-beginner">Beginner Friendly</span>
                    <% } %>

                    <span class="theme-pill info-pill <%= pitchStatusClass %>"><%= pitch.status %></span>
                </div>
            </div>

            <hr class="my-4">

            <div class="row g-4">
                <div class="col-lg-8">
                    <h3 class="fw-bold mb-3">Pitch Description</h3>
                    <p class="text-muted"><%= pitch.bio %></p>

                    <% if (pitch.portfolio) { %>
                        <div class="mt-4">
                            <h4 class="fw-bold mb-3">Portfolio</h4>
                            <p class="mb-0">
                                <a href="<%= pitch.portfolio %>" target="_blank" class="btn btn-outline-primary">View Portfolio</a>
                            </p>
                        </div>
                    <% } %>

                    <div class="mt-4">
                        <h4 class="fw-bold mb-3">Creator</h4>
                        <a href="/profile/<%= pitch.user_id %>" class="creator-link">
                            <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-4 border">
                                <img
                                    src="<%= pitch.profile_image_url && pitch.profile_image_url.trim() !== '' ? pitch.profile_image_url : 'https://via.placeholder.com/80x80?text=U' %>"
                                    alt="Creator"
                                    class="creator-avatar"
                                >
                                <div>
                                    <h5 class="mb-1"><%= pitch.display_name || pitch.name || 'User' %></h5>
                                    <p class="text-muted mb-0 text-capitalize"><%= pitch.profile_type || 'individual' %></p>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="bg-light rounded-4 p-4 border">
                        <h4 class="fw-bold mb-3">Pitch Details</h4>

                        <p><strong>Service Name:</strong><br><span class="text-muted"><%= pitch.name %></span></p>
                        <p><strong>Location:</strong><br><span class="text-muted"><%= pitch.location || 'N/A' %></span></p>
                        <p><strong>Location Type:</strong><br><span class="text-muted"><%= pitch.location_type || 'N/A' %></span></p>
                        <p><strong>Rate Type:</strong><br><span class="text-muted"><%= pitch.rate_type || 'Not listed' %></span></p>

                        <% if (pitch.rate_min !== null && pitch.rate_max !== null) { %>
                            <p><strong>Rate Range:</strong><br><span class="text-muted">$<%= pitch.rate_min %> - $<%= pitch.rate_max %></span></p>
                        <% } %>

                        <p><strong>Availability:</strong><br><span class="text-muted"><%= pitch.availability || 'Not listed' %></span></p>
                        <p><strong>Contact Email:</strong><br><span class="text-muted"><%= pitch.contact_email || 'Not listed' %></span></p>

                        <div class="d-grid gap-2 mt-4">
                            <% if (!isSaved) { %>
                                <form action="/savePitch/<%= pitch.id %>" method="POST">
                                    <button type="submit" class="btn btn-primary w-100">Save Pitch</button>
                                </form>
                            <% } else { %>
                                <form action="/unsavePitch/<%= pitch.id %>" method="POST">
                                    <button type="submit" class="btn btn-outline-danger w-100">Remove Saved Pitch</button>
                                </form>
                            <% } %>

                            <a href="mailto:<%= pitch.contact_email %>?subject=Interested in: <%= pitch.title %>" class="btn btn-outline-dark">
                                Contact Creator
                            </a>

                            <% if (isOwner) { %>
                                <a href="/updatePitch/<%= pitch.id %>" class="btn btn-warning">Update Pitch</a>
                                <a href="/completePitch/<%= pitch.id %>" class="btn btn-success">Mark Completed + Feedback</a>
                            <% } %>
                        </div>

                        <small class="text-muted d-block mt-3">
                            placeholder for something motivational or something.....
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>
