<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>OtterGigs | Update Gig</title>
    <style>
        body {
            background: #f8f9fa;
        }

        .form-card {
            border: none;
            border-radius: 22px;
            box-shadow: 0 10px 24px rgba(0,0,0,0.08);
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/home">
            <img src="/img/logo.png" alt="OtterGigs" class="site-logo" />
        </a>

        <div class="navbar-controls">
            <%- include("partials/navActions.ejs") %>
            <%- include("partials/navProfileButton.ejs", { profileImageUrl: user && user.profile_image_url }) %>
        </div>
    </div>
</nav>

<%- include("partials/userMenu.ejs") %>

<div class="container py-5">
    <div class="card form-card">
        <div class="card-body p-4 p-md-5">
            <h1 class="fw-bold mb-3">Update Gig</h1>
            <p class="text-muted mb-4">Edit your gig details and change its status.</p>

            <form action="/updateGig/<%= gig.id %>" method="POST" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Gig Title</label>
                    <input type="text" name="title" class="form-control" value="<%= gig.title %>" required>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Looking For</label>
                    <input type="text" name="looking_for" class="form-control" value="<%= gig.looking_for %>" required>
                </div>

                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="5" required><%= gig.description %></textarea>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select" required>
                        <option value="Art" <%= gig.category === 'Art' ? 'selected' : '' %>>Art</option>
                        <option value="Music" <%= gig.category === 'Music' ? 'selected' : '' %>>Music</option>
                        <option value="Design" <%= gig.category === 'Design' ? 'selected' : '' %>>Design</option>
                        <option value="Photography" <%= gig.category === 'Photography' ? 'selected' : '' %>>Photography</option>
                        <option value="Video" <%= gig.category === 'Video' ? 'selected' : '' %>>Video</option>
                        <option value="Writing" <%= gig.category === 'Writing' ? 'selected' : '' %>>Writing</option>
                        <option value="Marketing" <%= gig.category === 'Marketing' ? 'selected' : '' %>>Marketing</option>
                        <option value="Misc" <%= gig.category === 'Misc' ? 'selected' : '' %>>Misc</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Organization Name</label>
                    <input type="text" name="organization_name" class="form-control" value="<%= gig.organization_name || '' %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Urgency</label>
                    <select name="urgency" class="form-select">
                        <option value="Low" <%= gig.urgency === 'Low' ? 'selected' : '' %>>Low</option>
                        <option value="Medium" <%= gig.urgency === 'Medium' ? 'selected' : '' %>>Medium</option>
                        <option value="High" <%= gig.urgency === 'High' ? 'selected' : '' %>>High</option>
                        <option value="Urgent" <%= gig.urgency === 'Urgent' ? 'selected' : '' %>>Urgent</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" value="<%= gig.location || '' %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Location Type</label>
                    <select name="location_type" class="form-select">
                        <option value="On-site" <%= gig.location_type === 'On-site' ? 'selected' : '' %>>On-site</option>
                        <option value="Remote" <%= gig.location_type === 'Remote' ? 'selected' : '' %>>Remote</option>
                        <option value="Hybrid" <%= gig.location_type === 'Hybrid' ? 'selected' : '' %>>Hybrid</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Budget Text</label>
                    <input type="text" name="budget" class="form-control" value="<%= gig.budget || '' %>">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Budget Min</label>
                    <input type="number" step="0.01" name="budget_min" class="form-control" value="<%= gig.budget_min ?? '' %>">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Budget Max</label>
                    <input type="number" step="0.01" name="budget_max" class="form-control" value="<%= gig.budget_max ?? '' %>">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Deadline</label>
                    <input type="date" name="deadline" class="form-control" value="<%= gig.deadline ? new Date(gig.deadline).toISOString().split('T')[0] : '' %>">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Event Date</label>
                    <input type="date" name="event_date" class="form-control" value="<%= gig.event_date ? new Date(gig.event_date).toISOString().split('T')[0] : '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Image URL</label>
                    <input type="text" name="image_url" class="form-control" value="<%= gig.image_url || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Contact Email</label>
                    <input type="email" name="contact_email" class="form-control" value="<%= gig.contact_email || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="Open" <%= gig.status === 'Open' ? 'selected' : '' %>>Open</option>
                        <option value="Filled" <%= gig.status === 'Filled' ? 'selected' : '' %>>Filled</option>
                        <option value="Completed" <%= gig.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                        <option value="Closed" <%= gig.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                    </select>
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="beginner_friendly" value="1" id="beginnerFriendly" <%= gig.beginner_friendly ? 'checked' : '' %>>
                        <label class="form-check-label" for="beginnerFriendly">
                            Beginner Friendly
                        </label>
                    </div>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/gigInfo/<%= gig.id %>" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
